<Window x:Class="SmartOpsDesk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接设置"
        Width="760"
        Height="680"
        MinWidth="720"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="20">
        <Border Background="White" CornerRadius="8" Padding="22" BorderBrush="#E1E7EF" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="连接设置" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="在这里填写云数据库和 AI 分析接口。保存后主界面会重新加载数据。"
                               Foreground="#667085"
                               Margin="0,4,0,0" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="数据存储" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <TextBlock Text="存储模式" />
                        <ComboBox x:Name="StorageModeBox" Padding="8" Margin="0,4,0,12">
                            <ComboBoxItem Content="JSON" />
                            <ComboBoxItem Content="Supabase" />
                            <ComboBoxItem Content="Postgres" />
                            <ComboBoxItem Content="SQL Server" />
                        </ComboBox>

                        <TextBlock Text="Supabase / Postgres 连接串" />
                        <TextBox x:Name="SupabaseBox"
                                 MinHeight="70"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="8"
                                 Margin="0,4,0,8" />
                        <TextBlock Text="示例：Host=xxx.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.xxx;Password=你的密码;SSL Mode=Require"
                                   Foreground="#667085"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="SQL Server 连接串（可选）" />
                        <TextBox x:Name="SqlServerBox"
                                 MinHeight="54"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 Padding="8"
                                 Margin="0,4,0,18" />

                        <TextBlock Text="AI 分析" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

                        <TextBlock Text="AI Endpoint" />
                        <TextBox x:Name="LlmEndpointBox" Padding="8" Margin="0,4,0,12" />

                        <TextBlock Text="AI API Key" />
                        <PasswordBox x:Name="LlmApiKeyBox" Padding="8" Margin="0,4,0,12" />

                        <TextBlock Text="模型名" />
                        <TextBox x:Name="LlmModelBox" Padding="8" Margin="0,4,0,12" />

                        <Border Background="#F8FAFC" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,6,0,0">
                            <TextBlock Text="提示：如果不填写数据库连接，系统使用本地 JSON。AI 不填写 API Key 时，仍可使用规则 AI 分析。"
                                       Foreground="#475467"
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <DockPanel Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Foreground="#667085" VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="测试数据库连接" Width="130" Padding="12,8" Margin="0,0,8,0" Click="TestDatabase_Click" />
                        <Button Content="保存" Width="96" Padding="12,8" Margin="0,0,8,0" Background="#155EEF" Foreground="White" BorderBrush="#155EEF" Click="Save_Click" />
                        <Button Content="取消" Width="96" Padding="12,8" Click="Cancel_Click" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
