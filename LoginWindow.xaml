<Window x:Class="SmartOpsDesk.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SmartOpsDesk 登录"
        Width="520"
        Height="470"
        MinWidth="520"
        MinHeight="470"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="24">
        <Border Background="White" CornerRadius="8" Padding="28" BorderBrush="#E1E7EF" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="SmartOpsDesk" FontSize="30" FontWeight="Bold" />
                    <TextBlock Text="选择演示账号登录，不同角色拥有不同操作权限。"
                               Foreground="#667085"
                               TextWrapping="Wrap"
                               Margin="0,6,0,22" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="账号" />
                    <ComboBox x:Name="UserNameBox" Padding="8" Margin="0,4,0,14">
                        <ComboBoxItem Content="dev" IsSelected="True" />
                        <ComboBoxItem Content="pm" />
                        <ComboBoxItem Content="impl" />
                        <ComboBoxItem Content="ops" />
                    </ComboBox>

                    <TextBlock Text="密码" />
                    <PasswordBox x:Name="PasswordBox" Padding="8" Margin="0,4,0,14" Password="123456" />

                    <Border Background="#F8FAFC" BorderBrush="#EAECF0" BorderThickness="1" CornerRadius="6" Padding="12">
                        <TextBlock Text="演示账号：dev / pm / impl / ops，密码均为 123456。"
                                   Foreground="#475467"
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                    <Button Content="登录"
                            Width="108"
                            Padding="12,8"
                            Background="#155EEF"
                            Foreground="White"
                            BorderBrush="#155EEF"
                            Click="Login_Click" />
                    <Button Content="退出"
                            Width="108"
                            Padding="12,8"
                            Margin="10,0,0,0"
                            Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
